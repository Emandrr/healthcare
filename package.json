{
  "name": "Healthcare",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@sap/dev-cap-tools": "^1.31.0",
    "cds-plugin-ui5": "^0.17.0",
    "jest": "^30.4.2",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "test": "jest",
    "start": "cds-serve",
    "watch-admin-ui": "cds watch --open healthcare.admin.adminui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy Healthcare --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-doctor-ui": "cds watch --open com.healthcare.doctor.doctorui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-patient-ui": "cds watch --open com.healthcare.patient.patientui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "alice": {
              "roles": [
                "patient"
              ]
            },
            "admin": {
              "roles": [
                "doctor",
                "patient"
              ]
            }
          }
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/admin-ui",
    "app/doctor-ui",
    "app/admin-ui",
    "app/patient-ui",
    "app/admin-ui",
    "app/doctor-ui",
    "app/patient-ui",
    "app/doctor-ui",
    "app/patient-ui"
  ]
}
